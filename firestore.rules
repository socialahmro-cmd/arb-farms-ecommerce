rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Security rules for the orders collection
    match /orders/{orderId} {
      // 1. Allow guest checkout (creation of orders)
      allow create: if true;
      
      // 2. Allow receipt upload (customers updating status, receiptUploaded, and receiptUrl)
      allow update: if true;
      
      // 3. Restrict full read access and write management to authenticated admins
      allow read, delete: if request.auth != null && 
        (request.auth.token.email == 'social.ahmro@gmail.com' || 
         request.auth.token.email.matches('.*@arbfarms\\.com$'));
         
      // Allow admins full update capabilities
      allow update: if request.auth != null && 
        (request.auth.token.email == 'social.ahmro@gmail.com' || 
         request.auth.token.email.matches('.*@arbfarms\\.com$'));
    }
  }
}
