rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'social.ahmro@gmail.com' || 
         request.auth.token.email.matches('.*@arbfarms\\.com$') ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // Orders: anyone can create (guest checkout), users can list/read their own, admins read all
    match /orders/{orderId} {
      allow create: if true;
      allow list: if request.auth != null;
      allow get: if request.auth != null &&
                    resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // Users: read/write own profile, admins manage all
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId && 
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['landSizeStatus', 'tier']));
      allow read, write: if isAdmin();
    }

    // Products: anyone can read, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
