rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'social.ahmro@gmail.com' || 
         request.auth.token.email.matches('.*@arbfarms\\.com$') ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    match /products/{productId} {
      // Storefront reads product data publicly, no auth required
      allow read: if true;

      // Only admins can create/update/delete catalog data
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      // Anyone can place an order (guest checkout)
      allow create: if true;

      // Admins read all. Logged-in users read any order by direct ID
      // (dashboard fetches by doc ID — no composite index needed)
      allow read: if isAdmin() || request.auth != null;

      // Admins can update anything.
      // Logged-in users can ONLY claim an unclaimed order (no uid yet)
      // by writing their own uid onto it — nothing else changes.
      allow update: if isAdmin() || (
        request.auth != null &&
        resource.data.uid == null &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'email'])
      );

      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAdmin();
      allow read, create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
                    request.auth.uid == userId &&
                    !request.resource.data.diff(resource.data).affectedKeys()
                      .hasAny(['landSizeStatus', 'tier']);
    }
  }
}
